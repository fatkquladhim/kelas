generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Users of the system
model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("MAHASANTRI") // ADMIN, MAHASANTRI
  isActive  Boolean  @default(false) // Admin must confirm registration
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  classMemberships ClassMember[]
  materialAchievements MaterialAchievement[]
  pengumuman Pengumuman[]
  kehadiran Kehadiran[]

  // Group and Memorization relations
  ledKelompoks       Kelompok[]          @relation("KelompokLeader")
  kelompokMembers    KelompokMember[]
  verifiedHafalans   HafalanLog[]        @relation("HafalanVerifier")
  createdTugas       Tugas[]
  tugasDistributions TugasDistribution[]
}

// Classes / Kelas
model Kelas {
  id          String   @id @default(cuid())
  name        String
  semester    Int
  tahunAjaran String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members       ClassMember[]
  schedules     Jadwal[]
  pertemuanLogs PertemuanLog[]
  pengumuman    Pengumuman[]

  // Group and Tugas relations
  kelompoks     Kelompok[]
  tugas         Tugas[]
}

// Class membership with roles
model ClassMember {
  id        String   @id @default(cuid())
  kelasId   String
  userId    String
  role      String   @default("MAHASANTRI") // MAHASANTRI, ROIS_AM, KETUA_FAN_ILMU, KETUA_KELOMPOK, SEKRETARIS, BENDAHARA
  createdAt DateTime @default(now())

  kelas Kelas @relation(fields: [kelasId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([kelasId, userId])
}

// Courses / Mata Kuliah
model MataKuliah {
  id               String   @id @default(cuid())
  code             String
  name             String
  sks              Int      @default(2)
  semester         Int
  programStudi     String   @default("")
  standarKompetensi String  @default("")
  deskripsi        String   @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  syllabus  Silabus[]
  schedules Jadwal[]
  tugas     Tugas[]
}

// Syllabus items
model Silabus {
  id          String @id @default(cuid())
  mataKuliahId String
  pertemuan   Int
  materiPokok String @default("")
  subMateri   String @default("")
  referensi   String @default("")

  mataKuliah  MataKuliah @relation(fields: [mataKuliahId], references: [id], onDelete: Cascade)

  achievements   MaterialAchievement[]
  pertemuanLogs PertemuanLog[]
}

// Weekly Schedule
model Jadwal {
  id          String @id @default(cuid())
  mataKuliahId String
  kelasId     String
  hari        String   // AHAD, SENIN, SELASA, RABU, KAMIS, JUMAT, SABTU
  waktu       String   // PAGI, SORE, MALAM

  mataKuliah MataKuliah @relation(fields: [mataKuliahId], references: [id], onDelete: Cascade)
  kelas      Kelas      @relation(fields: [kelasId], references: [id], onDelete: Cascade)

  @@unique([kelasId, hari, waktu])
}

// Attendance records per meeting
model Kehadiran {
  id             String       @id @default(cuid())
  pertemuanLogId String
  userId         String
  status         String        // HADIR, IZIN, SAKIT, ALPA
  keterangan     String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  pertemuanLog PertemuanLog @relation(fields: [pertemuanLogId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pertemuanLogId, userId])
}

// Meeting logs - track which meetings have been held
model PertemuanLog {
  id          String   @id @default(cuid())
  silabusId   String
  kelasId     String
  tanggal     DateTime
  status      String   @default("BELUM") // SELESAI, BELUM, DITUNDA, ABSEN
  catatan     String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  silabus    Silabus     @relation(fields: [silabusId], references: [id], onDelete: Cascade)
  kelas      Kelas       @relation(fields: [kelasId], references: [id], onDelete: Cascade)
  kehadiran  Kehadiran[]
}

// Material achievement filled by Ketua Fan Ilmu
model MaterialAchievement {
  id             String   @id @default(cuid())
  silabusId      String
  kelasId        String
  userId         String   // Ketua Fan Ilmu who filled this
  tanggal        DateTime
  persentase     Int      @default(0) // 0-100
  deskripsi      String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  silabus Silabus @relation(fields: [silabusId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([silabusId, kelasId, tanggal])
}

// Announcements / Pengumuman
model Pengumuman {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String   @default("UMUM") // UMUM, JADWAL, UJIAN, LAINNYA
  kelasId   String?
  authorId  String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  kelas     Kelas?   @relation(fields: [kelasId], references: [id], onDelete: SetNull)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

// Group/Kelompok model
model Kelompok {
  id        String   @id @default(cuid())
  name      String
  kelasId   String
  leaderId  String   // User ID dari Ketua Kelompok
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  kelas     Kelas            @relation(fields: [kelasId], references: [id], onDelete: Cascade)
  leader    User             @relation("KelompokLeader", fields: [leaderId], references: [id], onDelete: Cascade)
  members   KelompokMember[]
  targets   HafalanTarget[]
  tasks     TugasDistribution[]
}

// Anggota Kelompok
model KelompokMember {
  id          String   @id @default(cuid())
  kelompokId  String
  userId      String
  createdAt   DateTime @default(now())

  kelompok    Kelompok @relation(fields: [kelompokId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hafalanLogs HafalanLog[]

  @@unique([kelompokId, userId])
}

// Target Hafalan ditentukan oleh Rois A'm
model HafalanTarget {
  id            String   @id @default(cuid())
  kelompokId    String
  materi        String   // Misal: "Surah Al-Baqarah 1-10"
  tanggalTarget DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  kelompok      Kelompok     @relation(fields: [kelompokId], references: [id], onDelete: Cascade)
  logs          HafalanLog[]
}

// Log kehadiran / setoran hafalan diisi oleh Ketua Kelompok (dinamis, tanpa perlu target dari Rois A'm)
model HafalanLog {
  id               String   @id @default(cuid())
  kelompokMemberId String
  targetId         String?  // Opsional — tidak wajib ada HafalanTarget
  materi           String   @default("") // Materi hafalan diisi langsung oleh Ketua Kelompok saat absen
  status           String   // "LANCAR", "KURANG_LANCAR", "BELUM_SETOR"
  catatan          String   @default("")
  tanggalSetor     DateTime @default(now())
  verifierId       String   // User ID dari Ketua Kelompok yang mengabsensi

  member   KelompokMember  @relation(fields: [kelompokMemberId], references: [id], onDelete: Cascade)
  target   HafalanTarget?  @relation(fields: [targetId], references: [id], onDelete: Cascade)
  verifier User            @relation("HafalanVerifier", fields: [verifierId], references: [id], onDelete: Cascade)
}

// Tugas yang dibuat oleh Rois Fan (Ketua Fan Ilmu)
model Tugas {
  id           String   @id @default(cuid())
  kelasId      String
  mataKuliahId String
  title        String
  description  String   @default("")
  dueDate      DateTime
  creatorId    String   // User ID dari KETUA_FAN_ILMU
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  kelas      Kelas      @relation(fields: [kelasId], references: [id], onDelete: Cascade)
  mataKuliah MataKuliah @relation(fields: [mataKuliahId], references: [id], onDelete: Cascade)
  creator    User       @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  distributions TugasDistribution[]
}

// Distribusi detail tugas ke masing-masing anggota oleh Ketua Kelompok
model TugasDistribution {
  id          String   @id @default(cuid())
  tugasId     String
  kelompokId  String
  userId      String   // Member yang ditugaskan
  taskDetail  String   @default("") // Deskripsi bagian tugas khusus dari ketua kelompok
  status      String   @default("BELUM") // "BELUM", "SELESAI"
  catatan     String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tugas     Tugas    @relation(fields: [tugasId], references: [id], onDelete: Cascade)
  kelompok  Kelompok @relation(fields: [kelompokId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tugasId, kelompokId, userId])
}
